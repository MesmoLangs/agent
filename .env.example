# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your personal Telegram chat ID (get from @userinfobot)
# Leave empty to allow anyone (not recommended)
ALLOWED_CHAT_ID=123456789

# Git commit identity
GIT_EMAIL=you@example.com
GIT_NAME=Claude Agent

# Branch to base all agent branches off
BASE_BRANCH=main

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# Your Bedrock inference profile ARN or model ID
# e.g. us.anthropic.claude-sonnet-4-5 or full ARN
ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-5

# ── GitHub Auth (choose one) ─────────────────────────────────────────────────

# Option A: GitHub App (recommended)
# Create at: https://github.com/organizations/YOUR_ORG/settings/apps
# Permissions needed — Repository: Contents (read & write), Metadata (read)
# After creating, generate a private key and install the app on your repos
# Encode the .pem file: base64 -i your-app.private-key.pem | tr -d '\n'
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=LS0tLS1CRUdJTiBSU0EgUFJJVkFURSBLRVktLS0tLQpZT1VSIEtFWSBIRVJFCi0tLS0tRU5EIFJTQSBQUklWQVRFIEtFWS0tLS0t
# Optional: set if the app is installed on multiple orgs
# GITHUB_APP_INSTALLATION_ID=

# Option B: SSH key (leave GITHUB_APP_ID unset to use this instead)
# Path to your SSH private key for git operations
# SSH_KEY_PATH=~/.ssh/github

# ── GitHub CLI ─────────────────────────────────────────────────────────────────
# Personal access token for gh CLI (API calls like gh repo list, gh pr create)
# Create at: https://github.com/settings/tokens
# When using GitHub App auth, this is auto-populated from the app token
GH_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Slack (optional — skip to disable Slack) ─────────────────────────────────
# Create a Slack app at https://api.slack.com/apps
# Enable Socket Mode to get the app-level token
# Bot Token Scopes: chat:write, channels:history, channels:read, app_mentions:read
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_CHANNEL_ID=C01ABCDEF,C02GHIJKL
