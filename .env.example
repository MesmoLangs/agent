# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your personal Telegram chat ID (get from @userinfobot)
# Leave empty to allow anyone (not recommended)
ALLOWED_CHAT_ID=123456789

# Contents of your SSH private key (the whole thing, newlines replaced with \n)
# Generate with: ssh-keygen -t ed25519 -C "claude-agent"
# Then add the PUBLIC key to GitHub: Settings → SSH Keys
GITHUB_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\nYOUR KEY HERE\n-----END OPENSSH PRIVATE KEY-----

# Git commit identity
GIT_EMAIL=you@example.com
GIT_NAME=Claude Agent

# Branch to base all agent branches off
BASE_BRANCH=main

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# Your Bedrock inference profile ARN or model ID
# e.g. us.anthropic.claude-sonnet-4-5 or full ARN
ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-5

# ── GitHub CLI ─────────────────────────────────────────────────────────────────
# Personal access token for gh CLI (API calls like gh repo list, gh pr create)
# Create at: https://github.com/settings/tokens
GH_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── SSH ────────────────────────────────────────────────────────────────────────
# Path to your SSH private key for git operations
SSH_KEY_PATH=~/.ssh/github
